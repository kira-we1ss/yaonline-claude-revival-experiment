YaLinkButton {
	min-height: -1px; min-width: -1px;
}

/*----------------------------------------------------------------------------
  MainWindow
----------------------------------------------------------------------------*/

#MainWindow #selfFrame,
#MainWindow #selfUserpicFrame {
	border-style: none;
}

#MainWindow #selfFrame {
	margin-left: 0px;
	margin-top: 0px;
} 

#MainWindow #selfUserpicFrame {
	border-style: none;
}

#MainWindow #selfUserpic/*,
YaEventNotifierFrame #eventNotifierUserpic*/ {
	border-style: none;
}

/*#MainWindow #selfName,*/
YaEventNotifierFrame #eventNotifierContactName {
	color: black;
	font-family: Arial serif;
	font-weight: bold;
	font-size: 11px;
	border-style: none;
}

YaEventNotifierFrame #eventNotifierReplies {
	font-size: 10px;
	color: #C84A09;
}

YaEventNotifierFrame #eventNotifierCount {
	color: gray;
	font-size: 8px;
}

/*YaEventNotifierFrame #readButton,
YaEventNotifierFrame #skipButton,
YaEventNotifierFrame #declineButton,
YaEventNotifierFrame #acceptButton {
	font-weight: bold;
	font-size: 9px;
}
*/
/* use YaEventNotifierFrame::setBackground() instead of this file */
YaEventNotifierFrame {
	border-width: 4px 5px 4px 5px;
}

YaEventNotifierFrame #eventNotifierCloseButton {
	border-style: none;
	background-position: center center;
	background-repeat: no-repeat;
}

YaEventNotifierFrame #eventNotifierMessage QTextEdit {
	color: #40311D;
	font-family: Arial serif;
	font-size: 10px;
}

#MainWindow #tabbedNotifier {
	border-style: none;
}

#MainWindow #friendsFrame {
	border-style: none;
}

#MainWindow #contactsFrame {
	border-style: none;
}

#MainWindow #addContactFrame {
	border-style: none;
}

#MainWindow #statusBar {
	font-family: "Tahoma";
	font-weight: bold;
	font-size: 10px;
}

/*----------------------------------------------------------------------------
  YaRosterTipLabel
----------------------------------------------------------------------------*/

#YaRosterTipLabel {
	font-size: 12px;
}

/*----------------------------------------------------------------------------
  YaPreferences
----------------------------------------------------------------------------*/

#YaPreferences QCheckBox,
#YaPreferences QRadioButton,
#YaPreferences QLabel {
	font-size: 12px;
}

#YaPreferences QCheckBox,
#YaPreferences QRadioButton {
	min-height: 15px;
	max-height: 15px;
}

#YaPreferences QLabel {
	min-height: 18px;
	max-height: 18px;
}

#YaPreferences #groupLabelContactList,
#YaPreferences #groupLabelNotifications,
#YaPreferences #groupLabelChat {
	color: #969696;
}

#YaPreferences QCheckBox:disabled {
	color: #969696;
}

/*----------------------------------------------------------------------------
  YaChatDlg
----------------------------------------------------------------------------*/

#YaGroupchatDlg #contactListFrame {
	border-image: url(:images/groupchat/splitter.png) 1px 1px 1px 1px stretch;
	border-width: 0px 0px 0px 1px;
}

#YaGroupchatDlg #editSubjectButton {
	border-image: none;
	border: 0px;
	background: url(:images/groupchat/edit_unlocked_idle.png) center center no-repeat;
}

#YaGroupchatDlg #editSubjectButton:hover {
	background: url(:images/groupchat/edit_unlocked_hover.png) center center no-repeat;
}

#YaGroupchatDlg #editSubjectButton:disabled,
#YaGroupchatDlg #editSubjectButton:disabled:hover {
	background: url(:images/groupchat/edit_locked_idle.png) center center no-repeat;
}

#YaGroupchatDlg #favoriteButton {
	border-image: none;
	border: 0px;
	background: url(:images/groupchat/fav_idle.png) center center no-repeat;
}

#YaGroupchatDlg #favoriteButton:hover {
	background: url(:images/groupchat/fav_hover.png) center center no-repeat;
}

#YaGroupchatDlg #favoriteButton:checked {
	background: url(:images/groupchat/fav_pressed.png) center center no-repeat;
}

#YaChatDlg #selfUserpic,
#YaChatDlg #contactUserpic,
#YaGroupchatDlg #selfUserpic,
#YaGroupchatDlg #contactUserpic,
YaRosterTipLabel #contactUserpic {
	border-style: none;
}

#YaChatDlg #chatTopFrame,
#YaGroupchatDlg #chatTopFrame
{
	border-style: none;
}

#YaChatDlg,
#YaGroupchatDlg {
	border-style: none;
}

#YaChatDlg #topFrame,
#YaChatDlg #bottomFrame,
#YaGroupchatDlg #topFrame,
#YaGroupchatDlg #bottomFrame
{
	border-style: none;
	border-width: 0px;
}

#MainWindow #applicationName,
#MainWindow #selfName,
#YaChatDlg #contactName,
#YaGroupchatDlg #contactName,
#YaManageAccounts #accountsLabel {
	font-weight: bold;
	font-size: 14px;

	color: white;
}

#YaRosterTipLabel #contactName {
	font-weight: bold;
	font-size: 12px;

	color: black;
}


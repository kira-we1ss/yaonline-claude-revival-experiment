QHeaderView::section {
	background-color: lightgray;
	color: black;
	padding-left: 4px;
	border: 0px solid #6c6c6c;
}

QHeaderView::down-arrow {
	image: url(:/images/down_arrow.png);
}

QHeaderView::up-arrow {
	image: url(:/images/up_arrow.png);
}

#YaMucJoin QLineEdit, #YaMucJoin QComboBox {
    border-image: url(:images/groupchat/join-lineedit.png) 2;
    border-width: 2;
}

#YaMucJoin #cb_account {
    border-image: url(:images/groupchat/join-lineedit2.png) 2;
}

#YaMucJoin #ck_password:indicator {
	image: url(:images/groupchat/join-unlocked.png);
}

#YaMucJoin #ck_password:indicator:checked {
	image: url(:images/groupchat/join-locked.png);
}

#YaMucJoin QTabWidget:pane {
	background-color: #C8EDFB;
	border: 0px;
	border-radius: 4px;
}

#YaMucJoin QTabWidget:tab-bar {
	left: 3px;
}

#YaMucJoin QTabBar:tab {
	font-size: 13px;

	border-radius: 3px;
	border-bottom-left-radius: 0px;
	border-bottom-right-radius: 0px;
	padding-top: 3px;
	padding-bottom: 3px;
	padding-left: 10px;
	padding-right: 10px;
}

#YaMucJoin QTabBar:tab {
	width: 40px;
}

#YaMucJoin QTabBar:tab:first, #YaMucJoin QTabBar:tab:last {
	width: 60px;
}

#YaMucJoin  QTabBar::tab:selected, #YaMucJoin  QTabBar::tab:hover {
	background-color: #C8EDFB;
	color: black;
 }

#YaMucJoin  QTabBar::tab:!selected {
	background-color: white;
	color: #828282;
	text-decoration: underline;
 }

#YaMucJoin {
	background-color: white;
}

#YaMucJoin #labelTitle {
	font-size: 16px;
	color: #74808C;
}

#YaMucJoin #labelTitleIcon {
	image: url(:images/groupchat/join-icon.png);
	min-width: 18px;
	max-width: 18px;
	min-height: 18px;
	max-height: 18px;
	border: 0px;
}

#YaMucJoin QLabel {
	font-size: 12px;
	font-weight: bold;
	color: black;
}

#YaMucJoin #ck_password {
	font-size: 11px;
	color: #688F9A;
	text-decoration: underline;
}

#YaMucJoin QComboBox:down-arrow {
	image: url(:images/down-arrow/normal.png);
}

#YaMucJoin QComboBox:drop-down {
	background-color: white;
	margin-top: 2px;
	margin-bottom: 2px;
}

/* --- */

QScrollBar:vertical {
	border-image: url(:images/scrollbar/background_inactive.png) 8 0 7 0 repeat;
	width: 14px;
	margin: 0px 0 0px 0;
	padding: 8px 0 8px 0;
}

QScrollBar:horizontal {
	height: 14px;
}

QScrollBar::handle:vertical {
	border-image: url(:images/scrollbar/handle_idle.png) 8px 0px 6px 0px stretch;
	border-width: 8px 0px 6px 0px;
	min-height: 14px;
}

QScrollBar::handle:vertical:hover:pressed {
	border-image: url(:images/scrollbar/handle_pressed.png) 8px 0px 6px 0px stretch;
}

QScrollBar::handle:vertical:hover {
	border-image: url(:images/scrollbar/handle_over.png) 8px 0px 6px 0px stretch;
}

QScrollBar::add-line:vertical {
	background-image: url(:images/scrollbar/dbutton_idle.png);
	height: 13px;
}

QScrollBar::sub-line:vertical {
	background-image: url(:images/scrollbar/ubutton_idle.png);
	height: 13px;
}

QScrollBar::add-line:vertical:hover:pressed {
	background-image: url(:images/scrollbar/dbutton_pressed.png);
}

QScrollBar::sub-line:vertical:hover:pressed {
	background-image: url(:images/scrollbar/ubutton_pressed.png);
}

QScrollBar::add-line:vertical:hover {
	background-image: url(:images/scrollbar/dbutton_over.png);
}

QScrollBar::sub-line:vertical:hover {
	background-image: url(:images/scrollbar/ubutton_over.png);
}

QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical {
	height: 0px;
}

QScrollBar::add-page:vertical {
	border-image: url(:images/scrollbar/background_inactive2.png) 8 0 7 0 repeat;
	border-width: 0px 0px 7px 0px;
}

QScrollBar::sub-page:vertical {
	border-image: url(:images/scrollbar/background_inactive2.png) 8 0 7 0 repeat;
	border-width: 8px 0px 0px 0px;
}

QScrollBar::add-page:vertical:pressed,
QScrollBar::sub-page:vertical:pressed {
	border-image: url(:images/scrollbar/background_active.png) 8 0 7 0 repeat;
}

